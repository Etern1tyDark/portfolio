---
import BlogCard from './BlogCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = await getCollection("posts").then(
  (posts: CollectionEntry<"posts">[]) =>
    posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
);
const sortedPosts = posts;
---

<section class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    {sortedPosts.length > 0 ? (
      <div class="grid md:grid-cols-2 gap-6 blog-grid" data-stagger-group>
        {sortedPosts.map((post: any) => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="text-6xl mb-4">📝</div>
        <h2 class="text-2xl font-bold mb-2 text-blue-400">No posts yet</h2>
        <p class="text-gray-400">Blog posts and CTF writeups will appear here soon.</p>
      </div>
    )}
  </div>
</section>

<style>
  .blog-grid {
    grid-auto-rows: auto;
  }
</style>
