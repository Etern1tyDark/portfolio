---
import { Image } from 'astro:assets';
import { resolveImageAsset } from '../utils/imageManifest';

interface AwardItem {
  result: string;
  event: string;
  date: string;
  awardedBy: string;
  scope: string;
  description: string;
  gallery?: string[];
}
interface OtherAwardItem {
  result: string;
  event: string;
  date: string;
}
interface Props {
  awards: AwardItem[];
  otherAwards: OtherAwardItem[];
}
const { awards, otherAwards } = Astro.props;
const isSvg = (path: string) => path.toLowerCase().endsWith('.svg');
---

<div class="stack-gap">
  <h2 class="text-3xl font-bold mb-6 text-blue-400 reveal-up">Awards & Achievements</h2>
  <div class="card-grid" data-stagger-group>
    {awards.map((award) => (
      <article class="card p-6 achievement-card award-card" data-stagger-item>
        <div class="award-carousel-wrap" data-award-carousel>
          <div class="carousel w-full rounded-lg award-carousel">
            {(award.gallery ?? []).map((image, index) => {
              const imageSrc = resolveImageAsset(image);
              const imageAlt = `${award.event} slide ${index + 1}`;

              return (
                <div class="carousel-item relative w-full" data-slide>
                  {isSvg(image) ? (
                    <Image class="award-photo lightbox-trigger" src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
                  ) : (
                    <Image class="award-photo lightbox-trigger" src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" format="webp" quality={80} />
                  )}
                </div>
              );
            })}
          </div>
          {(award.gallery?.length ?? 0) > 1 && (
            <div class="carousel-controls">
              <button type="button" class="btn btn-circle btn-xs" data-action="prev">{"<"}</button>
              <button type="button" class="btn btn-circle btn-xs" data-action="next">{">"}</button>
            </div>
          )}
        </div>

        <div class="award-head">
          <h3 class="text-lg font-bold text-green-400">{award.result} - {award.event}</h3>
          <span class="text-xs font-mono text-gray-400 mt-1">{award.date}</span>
        </div>
        <p class="text-sm text-gray-400">
          Awarded by {award.awardedBy} ({award.scope})
        </p>
        <p class="text-gray-300 leading-relaxed">{award.description}</p>
        {(award.gallery?.length ?? 0) > 1 && (
          <div class="slide-dots">
            {(award.gallery ?? []).map((_, index) => (
              <button type="button" class="btn btn-xs btn-circle dot-btn" data-dot={index}>{index + 1}</button>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>

  <div class="mt-10">
    <h3 class="text-2xl font-bold mb-5 text-gray-400 reveal-up">Other Awards</h3>
    <div class="card-grid" data-stagger-group>
      {otherAwards.map((award) => (
        <article class="card p-6 achievement-card" data-stagger-item>
          <div class="flex items-start justify-between gap-3">
            <h4 class="text-base font-bold text-green-400">{award.result} - {award.event}</h4>
            <span class="text-xs font-mono text-gray-400 mt-1">{award.date}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>

<dialog id="award-lightbox-modal" class="modal" tabindex="0">
  <div class="modal-box max-w-6xl p-2 bg-slate-900/95 border border-slate-700">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" aria-label="Close image preview">✕</button>
    </form>
    <div class="absolute left-2 right-2 top-1/2 -translate-y-1/2 flex justify-between pointer-events-none">
      <button id="award-lightbox-prev" type="button" class="btn btn-circle btn-sm pointer-events-auto">{"<"}</button>
      <button id="award-lightbox-next" type="button" class="btn btn-circle btn-sm pointer-events-auto">{">"}</button>
    </div>
    <img id="award-lightbox-image" src="" alt="" class="w-full h-auto max-h-[85vh] object-contain rounded-lg" />
    <div id="award-lightbox-counter" class="text-center text-xs text-gray-300 mt-2"></div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button aria-label="Close image preview">close</button>
  </form>
</dialog>

<style>
  .award-card {
    align-items: center;
    text-align: center;
  }

  .award-carousel-wrap {
    position: relative;
    width: 100%;
  }

  .award-carousel {
    border: 1px solid rgba(122, 162, 247, 0.28);
    background: rgba(15, 23, 42, 0.35);
  }

  .award-photo {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    cursor: zoom-in;
  }

  .award-head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: center;
  }

  .carousel-controls {
    position: absolute;
    left: 0.5rem;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .carousel-controls button {
    pointer-events: auto;
  }

  .slide-dots {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
  }

  .dot-btn {
    min-height: 1.3rem;
    height: 1.3rem;
  }

  .dot-btn.active-dot {
    background: var(--tokyo-blue);
    color: #0f172a;
    border-color: transparent;
  }
</style>

<script>
  const initAwardCarousels = () => {
    const modal = document.getElementById('award-lightbox-modal');
    const modalImage = document.getElementById('award-lightbox-image');
    const modalPrev = document.getElementById('award-lightbox-prev');
    const modalNext = document.getElementById('award-lightbox-next');
    const modalCounter = document.getElementById('award-lightbox-counter');
    const keyHandlerSlot = '__awardLightboxKeyHandler';
    let activeSlides = [];
    let activeIndex = 0;
    const isModalOpen = () => {
      if (!modal) return false;
      if (typeof modal.open === 'boolean') return modal.open;
      return modal.hasAttribute('open');
    };

    const updateModal = () => {
      if (!modalImage || !activeSlides.length) return;
      const current = activeSlides[activeIndex]?.querySelector('img');
      if (!current) return;

      const src = current.currentSrc || current.src;
      if (!src) return;

      modalImage.src = src;
      modalImage.alt = current.alt || 'Award image';
      if (modalCounter) {
        modalCounter.textContent = `${activeIndex + 1} / ${activeSlides.length}`;
      }

      const hasMultiple = activeSlides.length > 1;
      if (modalPrev) {
        modalPrev.disabled = !hasMultiple;
        modalPrev.classList.toggle('btn-disabled', !hasMultiple);
      }
      if (modalNext) {
        modalNext.disabled = !hasMultiple;
        modalNext.classList.toggle('btn-disabled', !hasMultiple);
      }
    };

    const stepModal = (direction) => {
      if (activeSlides.length <= 1) return;
      activeIndex = (activeIndex + direction + activeSlides.length) % activeSlides.length;
      updateModal();
    };

    const closeModal = () => {
      if (!modal) return;
      if (typeof modal.close === 'function') {
        modal.close();
      } else {
        modal.removeAttribute('open');
      }
    };

    const onKeyDown = (event) => {
      if (!isModalOpen()) return;
      if (event.key === 'ArrowLeft' || event.key === 'Left') {
        event.preventDefault();
        stepModal(-1);
      } else if (event.key === 'ArrowRight' || event.key === 'Right') {
        event.preventDefault();
        stepModal(1);
      } else if (event.key === 'Escape') {
        event.preventDefault();
        closeModal();
      }
    };

    if (modal && modal.dataset.lightboxBound !== '1') {
      modal.dataset.lightboxBound = '1';
      modalPrev?.addEventListener('click', () => stepModal(-1));
      modalNext?.addEventListener('click', () => stepModal(1));
      modal.addEventListener('keydown', onKeyDown);
    }

    if (window[keyHandlerSlot]) {
      window.removeEventListener('keydown', window[keyHandlerSlot]);
    }
    window[keyHandlerSlot] = onKeyDown;
    window.addEventListener('keydown', onKeyDown);

    const openLightbox = (slides, index) => {
      if (!modal || !modalImage) return;
      activeSlides = slides;
      activeIndex = index;
      updateModal();
      if (typeof modal.showModal === 'function') {
        modal.showModal();
      } else {
        modal.setAttribute('open', '');
      }
      if (typeof modal.focus === 'function') {
        modal.focus();
      }
    };

    const cards = document.querySelectorAll('.award-card');

    cards.forEach((card) => {
      const root = card.querySelector('[data-award-carousel]');
      if (!root || root.dataset.bound === '1') return;
      root.dataset.bound = '1';

      const slides = Array.from(root.querySelectorAll('[data-slide]'));
      const track = root.querySelector('.award-carousel');
      const prevBtn = root.querySelector('[data-action="prev"]');
      const nextBtn = root.querySelector('[data-action="next"]');
      const dots = Array.from(card.querySelectorAll('[data-dot]'));
      const canSlide = slides.length > 1 && !!track;

      let current = 0;

      const updateDots = () => {
        dots.forEach((dot, index) => {
          dot.classList.toggle('active-dot', index === current);
        });
      };

      const goTo = (target, smooth = true) => {
        if (!track || !slides.length) return;
        current = (target + slides.length) % slides.length;
        track.scrollTo({
          left: slides[current].offsetLeft,
          behavior: smooth ? 'smooth' : 'auto',
        });
        updateDots();
      };

      if (canSlide) {
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
      }

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = Number(dot.getAttribute('data-dot'));
          if (!Number.isNaN(idx)) goTo(idx);
        });
      });

      slides.forEach((slide) => {
        const img = slide.querySelector('img');
        if (!img || img.dataset.lightboxBound === '1') return;
        img.dataset.lightboxBound = '1';
        const idx = slides.indexOf(slide);
        img.addEventListener('click', () => openLightbox(slides, idx));
      });

      if (canSlide) {
        goTo(0, false);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAwardCarousels, { once: true });
  } else {
    initAwardCarousels();
  }

  document.addEventListener('astro:page-load', initAwardCarousels);
</script>
