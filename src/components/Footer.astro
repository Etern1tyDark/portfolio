---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { 
    name: 'Email', 
    href: 'mailto:nathankhopancras@gmail.com', 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`
  },
  { 
    name: 'LinkedIn', 
    href: 'https://www.linkedin.com/in/nathan-k-pancras/', 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`
  },
  { 
    name: 'GitHub (Personal)', 
    href: 'https://github.com/Etern1tyDark', 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`
  },
  { 
    name: 'GitHub (College)', 
    href: 'https://github.com/NathanKhoP', 
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/><circle cx="12" cy="12" r="3" fill="currentColor" opacity="0.3"/></svg>`
  },
];
---

<footer class="footer border-t border-gray-700/50 bg-gray-900/50 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Left: Logo/Name -->
      <div class="flex items-center gap-2">
        <!-- <span class="text-lg font-bold text-blue-400 font-mono">Portfolio</span> -->
        <span class="text-gray-500 text-sm">Nathan Kho Pancras &copy; {currentYear}</span>
      </div>

      <!-- Right: Social Links -->
      <div class="flex items-center gap-4">
        {socialLinks.map((link) => (
          <a 
            href={link.href} 
            target="_blank" 
            rel="noopener noreferrer"
            class="social-link text-gray-400 hover:text-blue-400 transition-all duration-200"
            aria-label={link.name}
            title={link.name}
          >
            <Fragment set:html={link.icon} />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(180deg, rgba(31, 35, 53, 0.5) 0%, rgba(26, 27, 38, 0.8) 100%);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.5rem;
    background: rgba(86, 95, 137, 0.1);
    border: 1px solid rgba(86, 95, 137, 0.2);
  }

  .social-link:hover {
    background: rgba(122, 162, 247, 0.15);
    border-color: rgba(122, 162, 247, 0.4);
    transform: translateY(-2px);
  }

  html.light .footer {
    background: linear-gradient(180deg, rgba(241, 243, 247, 0.8) 0%, rgba(233, 236, 242, 0.95) 100%);
  }

  html.light .social-link {
    background: rgba(200, 205, 220, 0.3);
    border-color: rgba(180, 185, 200, 0.4);
    color: #4b5563;
  }

  html.light .social-link:hover {
    background: rgba(37, 99, 235, 0.1);
    border-color: rgba(37, 99, 235, 0.4);
    color: #2563eb;
  }
</style>
