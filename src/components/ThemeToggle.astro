---

<button id="effects-toggle" class="bg-gray-700 text-white px-3 py-2 rounded-md hover:bg-gray-600 transition-colors text-sm font-semibold" aria-label="Toggle effects">
  <span id="effects-on">FX ON</span>
  <span id="effects-off" class="hidden">FX OFF</span>
</button>

<script>
  const applyState = (off: boolean) => {
    document.body.classList.toggle('no-effects', off);
    localStorage.setItem('effects', off ? 'off' : 'on');
    const onLabel = document.getElementById('effects-on');
    const offLabel = document.getElementById('effects-off');
    if (onLabel && offLabel) {
      if (off) {
        onLabel.classList.add('hidden');
        offLabel.classList.remove('hidden');
      } else {
        onLabel.classList.remove('hidden');
        offLabel.classList.add('hidden');
      }
    }
  };

  const bindToggle = () => {
    const toggle = document.getElementById('effects-toggle') as HTMLButtonElement | null;
    if (!toggle) return;

    const stored = localStorage.getItem('effects');
    const off = stored === 'off';
    applyState(off);

    toggle.onclick = () => {
      const isOff = document.body.classList.contains('no-effects');
      const next = !isOff;
      applyState(next);
      toggle.animate(
        [{ transform: 'rotate(-180deg)' }, { transform: 'rotate(0deg)' }],
        { duration: 500, easing: 'cubic-bezier(0.4, 0, 0.2, 1)' },
      );
      window.dispatchEvent(new CustomEvent('effects-toggle', { detail: { off: next } }));
    };
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindToggle, { once: true });
  } else {
    bindToggle();
  }

  document.addEventListener('astro:page-load', bindToggle);
</script>
