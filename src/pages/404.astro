---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { withBasePath } from '../utils/withBasePath';
---

<Layout
  title="404 | Nathan Kho Pancras (eter) | Portfolio"
  description="Page not found."
  canonicalPath="/404"
  noindex
  disableRubber
>
  <Navbar />
  <main class="min-h-screen flex items-center justify-center px-4 py-20">
    <section class="card w-full max-w-2xl p-8 text-center">
      <p class="text-sm tracking-[0.28em] uppercase text-gray-400 mb-3">Error</p>
      <h1 class="text-5xl font-bold text-blue-400 mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-gray-200 mb-3">Page not found</h2>
      <p class="text-gray-400 max-w-xl mx-auto mb-8">
        The page you requested does not exist, may have moved, or the URL is incorrect.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={withBasePath('/')} class="btn btn-primary w-full sm:w-auto">Back to Home</a>
      </div>
    </section>
  </main>
</Layout>
