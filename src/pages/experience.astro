---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ExperienceHero from '../components/ExperienceHero.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import ExperienceHighlights from '../components/ExperienceHighlights.astro';
import ExperienceSpeakingProjects from '../components/ExperienceSpeakingProjects.astro';
import ExperienceCommittees from '../components/ExperienceCommittees.astro';
import experienceData from '../data/experience.json';

const site = Astro.site ?? new URL('https://yourusername.pages.dev');
const description =
  'Experience timeline, awards, committees, and projects by Nathan Kho Pancras in cybersecurity and systems engineering.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  url: new URL('/experience', site).href,
  name: 'Experience | Nathan Kho Pancras (eter) | Portfolio',
  description,
};
---

<Layout
  title="Experience | Nathan Kho Pancras (eter) | Portfolio"
  description={description}
  canonicalPath="/experience"
  jsonLd={jsonLd}
>
  <Navbar currentPath="/experience" />
  <main class="min-h-screen">
    <ExperienceHero />
    <section class="py-20 px-4">
      <div class="max-w-5xl mx-auto">
        <ExperienceTimeline experiences={experienceData.experiences} />
        <ExperienceHighlights awards={experienceData.awards} otherAwards={experienceData.otherAwards} />
        <ExperienceSpeakingProjects projects={experienceData.projects} />
        <ExperienceCommittees committees={experienceData.committees} />
      </div>
    </section>
  </main>
</Layout>

<style>
  :global(.stack-gap) {
    margin-top: 2.5rem;
  }

  @media (min-width: 768px) {
    :global(.stack-gap) {
      margin-top: 4rem;
    }
  }

  :global(.card-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  :global(.card-grid .card) {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: linear-gradient(140deg, rgba(36, 40, 59, 0.96), rgba(20, 24, 37, 0.94));
    border: 1px solid rgba(86, 95, 137, 0.65);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.4);
  }

  :global(.achievement-card ul) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
    color: rgba(192, 202, 245, 0.85);
  }

  :global(.achievement-card a.btn) {
    margin-top: auto;
    align-self: flex-start;
  }
</style>
