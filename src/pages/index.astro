---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import HomeHero from '../components/HomeHero.astro';

const site = Astro.site ?? new URL('https://yourusername.pages.dev');
const description =
  'Nathan Kho Pancras - cybersecurity portfolio featuring CTF work, cryptography, digital forensics, red teaming, and software projects.';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Nathan Kho Pancras',
    url: new URL('/', site).href,
    inLanguage: 'en',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Nathan Kho Pancras',
    url: new URL('/', site).href,
    jobTitle: 'Cybersecurity Student',
    sameAs: [
      'https://github.com/Etern1tyDark',
      'https://github.com/NathanKhoP',
      'https://www.linkedin.com/in/nathan-k-pancras/',
    ],
  },
];
---

<Layout
  title="Nathan Kho Pancras (eter) | Portfolio"
  description={description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <Navbar currentPath="/" />
  <main class="min-h-screen">
    <HomeHero />
  </main>
</Layout>
