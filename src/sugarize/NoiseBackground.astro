<canvas id="noisy" class="fixed inset-0 pointer-events-none opacity-65 mix-blend-soft-light z-20"></canvas>

<style>
  body.no-effects #noisy {
    display: none !important;
  }
</style>

<script>
  function resize(canvas: HTMLCanvasElement) {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function buildNoise(
    canvas: HTMLCanvasElement,
    ctx: CanvasRenderingContext2D
  ) {
    const imageData = ctx.createImageData(canvas.width, canvas.height);
    const data = imageData.data;
    for (let i = 0; i < data.length; i += 4) {
      const value = Math.random() * 255;
      data[i] = value; // r
      data[i + 1] = value; // g
      data[i + 2] = value; // b
      data[i + 3] = 48; // a — stronger grain
    }
    ctx.putImageData(imageData, 0, 0);
  }

  function animate(canvas: HTMLCanvasElement, ctx: CanvasRenderingContext2D) {
    buildNoise(canvas, ctx);
    requestAnimationFrame(() => animate(canvas, ctx));
  }

  function init() {
    const noisy = document.getElementById("noisy") as HTMLCanvasElement;
    if (!noisy) return;
    const ctx = noisy.getContext("2d")!;
    if (!ctx) return;
    resize(noisy);
    window.addEventListener("resize", () => resize(noisy));
    animate(noisy, ctx);
  }

  init();
</script>